# KittenTTS Service Environment Configuration

# Database Configuration
DB_PATH=/var/lib/taas-db/tasks.db

# Audio Output Configuration
AUDIO_OUTPUT_DIR=/var/lib/taas-audio

# Model Cache Configuration
MODEL_CACHE_DIR=/var/lib/taas-models

# Model Configuration - Choose from:
# KittenML/kitten-tts-mini-0.8 (80MB, highest quality)
# KittenML/kitten-tts-micro-0.8 (40MB, balanced)
# KittenML/kitten-tts-nano-0.8 (15MB, fastest)
KITTEN_MODEL=KittenML/kitten-tts-mini-0.8

# Worker Configuration
MAX_WORKERS=5
MAX_QUEUE_DEPTH=1000
MAX_TEXT_LENGTH=64000

# File Cleanup Configuration
AUDIO_TTL_HOURS=12

# Logging Configuration
LOG_LEVEL=INFO

# Server Configuration
HOST=0.0.0.0
PORT=8000

# API Versioning
API_VERSION=v1

# Available voices from KittenTTS
AVAILABLE_VOICES=Bella,Jasper,Luna,Bruno,Rosie,Hugo,Kiki,Leo
DEFAULT_VOICE=Leo

# Audio Format Configuration
SAMPLE_RATE=24000
AUDIO_FORMAT=wav